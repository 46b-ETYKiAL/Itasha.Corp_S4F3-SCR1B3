# Deterministic line endings across Windows/Linux/macOS contributors.
# Without this, normalization depends on each contributor's core.autocrlf,
# which produces spurious CRLF/LF diffs and "LF will be replaced by CRLF"
# warnings. Store everything as LF in the repo and check it out as LF.
* text=auto eol=lf

# Explicit text types (belt-and-suspenders over the auto detection).
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sh    text eol=lf
*.ps1   text eol=lf

# Binary assets — never normalize or diff as text.
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.icns     binary
*.gz       binary
*.zip      binary
*.wasm     binary
*.minisig  binary
